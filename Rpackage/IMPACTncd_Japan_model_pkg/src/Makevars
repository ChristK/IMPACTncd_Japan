# C++17 is required for constexpr if and std::is_same_v
CXX_STD = CXX17

# OpenMP support for parallel processing in fit_beta_vec_cpp
# On Linux/Windows: SHLIB_OPENMP_CXXFLAGS is typically -fopenmp
# On macOS: SHLIB_OPENMP_CXXFLAGS is typically empty (clang doesn't include OpenMP by default)
#           To enable OpenMP on macOS, install libomp via Homebrew and add to ~/.R/Makevars:
#           CPPFLAGS += -Xclang -fopenmp -I/opt/homebrew/opt/libomp/include
#           LDFLAGS += -L/opt/homebrew/opt/libomp/lib -lomp
# The code gracefully falls back to sequential execution when OpenMP is unavailable.

PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -I"$(R_HOME)/library/data.table/include" -include undef_fortify.h
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS)
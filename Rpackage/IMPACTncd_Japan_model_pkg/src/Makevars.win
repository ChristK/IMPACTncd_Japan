# C++17 is required for constexpr if and std::is_same_v
CXX_STD = CXX17

# OpenMP support for parallel processing in fit_beta_vec_cpp
# On Windows with Rtools, OpenMP is typically available via -fopenmp
# The code gracefully falls back to sequential execution when OpenMP is unavailable.

PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) -I"$(R_HOME)/library/data.table/include"
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS)